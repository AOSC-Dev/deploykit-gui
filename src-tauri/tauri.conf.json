{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "./icons/aosc-os.svg"
    ]
  },
  "productName": "deploykit-gui",
  "version": "0.1.0",
  "identifier": "io.aosc.deploykit",
  "plugins": {
    "cli": {
      "description": "Depliykit GUI",
      "args": [
        {
          "name": "skip",
          "short": "s",
          "description": "Skip select Desktop or Install view"
        },
        {
          "name": "resource-dir",
          "short": "d",
          "description": "Resource directory",
          "takesValue": true,
          "required": true
        }
      ]
    }
  },
  "app": {
    "windows": [
      {
        "fullscreen": true,
        "resizable": true,
        "title": "deploykit-gui",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  }
}